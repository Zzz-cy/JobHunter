# ============================================================
# JobHunter 后端环境变量模板
#
# 使用方法：
#   1. 复制本文件为 .env: cp .env.example .env
#   2. 修改 .env 中的值为本机真实配置
#   3. .env 已被 .gitignore 忽略，不会提交到 git
# ============================================================

# ---------- App ----------
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
# JWT 密钥(生产环境用 openssl rand -hex 32 生成)
JWT_SECRET_KEY=change-me-in-production-please-use-32-chars-at-least
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ---------- MySQL ----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=jobhunter
MYSQL_POOL_SIZE=10
MYSQL_POOL_RECYCLE=3600
MYSQL_ECHO=false

# ---------- Elasticsearch (后续启用) ----------
ES_URL=http://127.0.0.1:9200
ES_USERNAME=elastic
ES_PASSWORD=your_password_here
ES_VERIFY_CERTS=false

# ---------- Neo4j (后续启用) ----------
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ---------- 讯飞星火 API (后续启用) ----------
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
